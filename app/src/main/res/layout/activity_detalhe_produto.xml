<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="15dp"
    android:background="@color/white"
    tools:context=".activities.DetalheProdutoActivity">

    <ImageView
        android:id="@+id/imgProduto"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="76dp"

        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/hortlink_logo" />

    <Button
        android:id="@+id/btnCarrinho"
        android:layout_width="200dp"
        android:layout_height="45dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="84dp"
        android:paddingHorizontal="20dp"
        android:text="Adicionar ao carrinho"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.994"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtPreco" />

    <ImageView
        android:id="@+id/additem"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/remove_white"
        android:background="@drawable/bg_redondo"
        app:layout_constraintBottom_toTopOf="@+id/cardProdutor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/quantidade"
        app:layout_constraintTop_toBottomOf="@+id/txtDescricao"
         />

    <TextView
        android:id="@+id/quantidade"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="@color/black_soft"
        android:textStyle="bold"
        android:textSize="30sp"
        app:layout_constraintStart_toEndOf="@+id/additem"
        app:layout_constraintEnd_toStartOf="@+id/removeitem"
        app:layout_constraintTop_toBottomOf="@+id/txtDescricao"
        app:layout_constraintBottom_toTopOf="@+id/cardProdutor" />

    <ImageView
        android:id="@+id/removeitem"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/add_white"
        android:background="@drawable/bg_redondo"
        app:layout_constraintBottom_toTopOf="@+id/cardProdutor"
        app:layout_constraintStart_toEndOf="@+id/quantidade"
        app:layout_constraintEnd_toStartOf="@+id/btnCarrinho"
        app:layout_constraintTop_toBottomOf="@+id/txtDescricao"
         />


    <TextView
        android:id="@+id/txtPreco"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        android:text="R$ 0,00"
        android:textColor="@color/green"
        android:textSize="17sp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtNome" />

    <TextView
        android:id="@+id/txtNome"
        android:layout_width="wrap_content"
        android:layout_height="37dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="16dp"

        android:textColor="@color/black_soft"
        android:text="Nome do produto"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgProduto" />

    <TextView
        android:id="@+id/txtDescricao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="Descrição"
        android:textColor="@color/black_soft"
        android:textSize="17sp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtPreco" />

    <ImageButton
        android:id="@+id/btnVoltar"
        android:layout_width="48dp"
        android:layout_height="48dp"

        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="15dp"

        android:src="@drawable/back_white"
        android:background="@drawable/shape_btn_voltar"
        android:backgroundTint="@color/green_700"

        android:padding="12dp"

        app:layout_constraintBottom_toTopOf="@+id/imgProduto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/cardProdutor"
        android:padding="10dp"
        android:layout_marginHorizontal="20dp"
       android:background="@drawable/bg_categoria"
        app:layout_constraintTop_toBottomOf="@id/btnCarrinho"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/fotoPerfil"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_redondo"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:srcCompat="@tools:sample/avatars" />

        <!-- mesma linha que o nome -->

        <TextView
            android:id="@+id/txtNomeProd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Nome do produtor"
            android:textColor="@color/black_soft"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/fotoPerfil"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtContatoProd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/black_soft"
            android:text="Telefone"
            app:layout_constraintStart_toEndOf="@+id/fotoPerfil"
            app:layout_constraintTop_toBottomOf="@+id/txtCidadeProd" />

        <TextView
            android:id="@+id/txtCidadeProd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black_soft"
            android:layout_marginStart="8dp"
            android:text="Cidade, UF"
            app:layout_constraintStart_toEndOf="@+id/fotoPerfil"
            app:layout_constraintTop_toBottomOf="@+id/txtNomeProd" />

         <!-- abaixo do nome -->

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>