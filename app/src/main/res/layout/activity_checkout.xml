<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F0">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#2E7D32"
        android:paddingHorizontal="18dp"
        android:paddingVertical="20dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/cart"
            app:tint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Finalizar Compra"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- CONTEÚDO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- ÍCONE -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/payments_gren300"
            android:alpha="0.9"
            app:tint="#2E7D32"/>

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Confirmação de Pagamento"
            android:textColor="#212121"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <!-- SUBTEXTO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Finalize sua compra para enviar o pedido ao produtor."
            android:textAlignment="center"
            android:textColor="#757575"
            android:textSize="15sp"/>

        <!-- CARD STATUS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:background="@drawable/bg_checkout_status"
            android:padding="20dp">

            <!-- TEXTO STATUS -->
            <TextView
                android:id="@+id/tv_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pronto para pagamento"
                android:textColor="#424242"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <!-- DESCRIÇÃO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Seu pedido será enviado ao produtor após a confirmação."
                android:textColor="#757575"
                android:textSize="14sp"/>

            <!-- SPINNER -->
            <ProgressBar
                android:id="@+id/spinner"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="18dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

    <!-- FOOTER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:orientation="vertical"
        android:padding="18dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pagar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Pagar Agora"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</LinearLayout>