<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    tools:context=".activities.EditarProdutosFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:text="Editar Produto"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Atualize as informações do seu produto 🛠️"
            android:textSize="14sp"
            android:textColor="#6B6B6B"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Upload de Foto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto do Produto"
            android:textColor="#2E7D32"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <FrameLayout
            android:id="@+id/frameUploadFoto"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_upload_foto"
            android:clickable="true"
            android:focusable="true">

            <!-- Placeholder -->
            <LinearLayout
                android:id="@+id/layoutPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:alpha="0.4"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toque para adicionar uma foto"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <!-- Foto selecionada / carregada -->
            <ImageView
                android:id="@+id/imgProduto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- NOME -->
        <EditText
            android:id="@+id/edtNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do produto"
            android:textColorHint="@color/black_soft"
            android:textColor="@color/black_soft"
            android:layout_marginTop="20dp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="textCapWords"/>

        <!-- DESCRIÇÃO -->
        <EditText
            android:id="@+id/edtDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descrição"
            android:textColorHint="@color/black_soft"
            android:textColor="@color/black_soft"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="textMultiLine"/>

        <!-- PREÇO -->
        <EditText
            android:id="@+id/edtPreco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Preço (R$)"
            android:textColorHint="@color/black_soft"
            android:textColor="@color/black_soft"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="numberDecimal"/>

        <!-- BOTÃO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAtualizar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Salvar Produto"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="12dp"/>

        <!-- Botão Cancelar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Cancelar"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#2E7D32"
            app:strokeWidth="1.5dp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

</ScrollView>