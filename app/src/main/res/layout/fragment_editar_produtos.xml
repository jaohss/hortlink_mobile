<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    tools:context=".activities.EditarProdutosFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:text="Editar Produto"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Atualize as informações do seu produto 🛠️"
            android:textSize="14sp"
            android:textColor="#6B6B6B"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- IMAGEM -->
        <ImageView
            android:id="@+id/imgProduto"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera"
            android:background="#E0E0E0"
            android:padding="8dp"/>

        <TextView
            android:text="Toque para alterar a foto"
            android:textSize="12sp"
            android:textColor="#777"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- NOME -->
        <EditText
            android:id="@+id/edtNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do produto"
            android:layout_marginTop="20dp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="textCapWords"/>

        <!-- DESCRIÇÃO -->
        <EditText
            android:id="@+id/edtDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descrição"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="textMultiLine"/>

        <!-- PREÇO -->
        <EditText
            android:id="@+id/edtPreco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Preço (R$)"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="numberDecimal"/>

        <!-- BOTÃO -->
        <Button
            android:id="@+id/btnAtualizar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Atualizar Produto"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>