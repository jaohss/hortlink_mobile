<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- CAPA VERDE + BOTÃO VOLTAR sobreposto -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="110dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:background="@color/green"/>

            <ImageButton
                android:id="@+id/btnVoltar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_margin="10dp"
                android:background="@drawable/bg_redondo"
                android:src="@drawable/home"
                android:contentDescription="Voltar"/>
        </FrameLayout>

        <!-- AVATAR sobreposto à capa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginTop="-40dp"
            android:paddingTop="48dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <!-- Avatar posicionado sobre a capa -->
            <ImageView
                android:id="@+id/imgFazenda"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/hortlink_logo"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_redondo"
                android:layout_marginTop="-88dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/txtNomeProd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do produtor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <!-- Cidade + Avaliação na mesma linha -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/home"
                    app:tint="#888888"/>

                <TextView
                    android:id="@+id/txtCidadeProd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cidade, Estado"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#CCCCCC"/>

                <TextView
                    android:id="@+id/txtAvaliacao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 0.0"
                    android:textSize="13sp"
                    android:textColor="#666666"/>
            </LinearLayout>

            <!-- Contato -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/telephone"
                    app:tint="#3B6D11"/>

                <TextView
                    android:id="@+id/txtContatoProd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contato não informado"
                    android:textSize="13sp"
                    android:textColor="#3B6D11"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Descrição -->
            <TextView
                android:id="@+id/txtDescricao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descrição da produção"
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="12dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <!-- PRODUTOS DO PRODUTOR -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Produtos disponíveis"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerProdutosPerfil"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"/>

    </LinearLayout>
</ScrollView>