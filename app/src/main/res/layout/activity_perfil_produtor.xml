<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F0">

    <!-- ── IMAGEM DE CAPA (hero) + botão voltar sobreposto ── -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imgCapa"
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:scaleType="centerCrop"
        android:src="@drawable/hortlink_logo"/>

    <!-- Gradiente sobre a capa para o botão ficar legível -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/gradient_top_black"
        android:layout_gravity="top"/>

    <!-- Botão voltar flutuante -->
    <ImageButton
        android:id="@+id/btnVoltar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_margin="12dp"
        android:layout_gravity="top|start"
        android:background="@drawable/bg_redondo"
        android:src="@drawable/back_white"
        android:contentDescription="Voltar"/>

    <!-- ── CARD BRANCO que sobe sobre a imagem ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="190dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">
            <!-- Card branco com cantos arredondados no topo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp"
                android:background="@drawable/bg_card_top_rounded"
                android:paddingHorizontal="20dp"
                android:paddingTop="40dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Avatar + nome + localização -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginTop="-36dp">

                    <!-- Avatar circular -->
                    <ImageView
                        android:id="@+id/imgFazenda"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/hortlink_logo"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_redondo"
                        android:clipToOutline="true"/>

                    <!-- Nome + localização -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/txtNomeProd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nome do produtor"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <!-- Cidade, UF -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <ImageView
                                android:layout_width="13dp"
                                android:layout_height="13dp"
                                android:src="@drawable/home"
                                app:tint="#888888"/>

                            <TextView
                                android:id="@+id/txtCidadeProd"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cidade, UF"
                                android:textSize="12sp"
                                android:textColor="#777777"
                                android:layout_marginStart="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- Telefone -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/telephone"
                        app:tint="@color/green"/>

                    <TextView
                        android:id="@+id/txtContatoProd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(00) 00000-0000"
                        android:textSize="13sp"
                        android:textColor="@color/green"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginVertical="16dp"/>

                <!-- Descrição -->
                <TextView
                    android:id="@+id/txtDescricao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descrição da produção"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ── SEÇÃO PRODUTOS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:layout_marginTop="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Produtos disponíveis"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:paddingHorizontal="20dp"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerProdutosPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:clipToPadding="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="horizontal"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── BOTÃO FLUTUANTE "Ver todos os produtos" ── -->
    <Button
        android:id="@+id/btnVerProdutos"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="@color/green"
        android:text="Ver todos os produtos"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>