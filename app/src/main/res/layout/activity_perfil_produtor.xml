<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cinza_fundo">

    <!-- Foto Capa -->
    <ImageView
        android:id="@+id/imgCapa"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/fotocapa"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Foto Perfil (sobreposta à capa) -->
    <ImageView
        android:id="@+id/imgFotoPerfil"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:background="@drawable/bg_redondo"
        app:srcCompat="@drawable/fazenda"
        android:layout_marginTop="150dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nome -->
    <TextView
        android:id="@+id/txtNomeProd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="nome"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/imgFotoPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Avaliação | Cidade -->
    <TextView
        android:id="@+id/txtAvaliacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐ 0.0"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtNomeProd"
        app:layout_constraintEnd_toStartOf="@id/txtCidadeProd" />

    <TextView
        android:id="@+id/txtCidadeProd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="cidade"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtNomeProd"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtContatoProd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="contato"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtNomeProd"
        app:layout_constraintStart_toEndOf="@id/txtCidadeProd" />

    <!-- Descrição -->
    <TextView
        android:id="@+id/txtDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Descrição do produtor"
        android:textSize="15sp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtCidadeProd"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botão Ver Produtos -->
    <Button
        android:id="@+id/maisProd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ver Produtos"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>