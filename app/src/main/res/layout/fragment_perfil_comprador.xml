<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- TOOLBAR -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@android:color/white"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Meu perfil"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>
        </RelativeLayout>

        <!-- CARD PERFIL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/imgPerfilComprador"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/hortlink_logo"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_redondo"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/txtNomeComprador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:id="@+id/txtCidadeComprador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cidade, Estado"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/txtEmailComprador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@exemplo.com"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- SEÇÃO: COMPRAS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Minhas compras"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <!-- Meus pedidos -->
            <LinearLayout
                android:id="@+id/btnMeusPedidos"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@android:color/white"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#EAF3DE"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/pedidos"
                        app:tint="#3B6D11"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:text="Meus pedidos"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="Acompanhar compras"
                        android:textSize="11sp"
                        android:textColor="#999"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- SEÇÃO: CONTA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Conta"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginHorizontal="12dp">

            <!-- Editar perfil -->
            <LinearLayout
                android:id="@+id/btnEditarPerfil"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/editar_perfil"
                    app:tint="#555555"/>
                <TextView
                    android:text="Editar perfil"
                    android:textSize="13sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginStart="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#F0F0F0" android:layout_marginStart="46dp"/>

            <!-- Configurações -->
            <LinearLayout
                android:id="@+id/itemConfiguracoes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/settings_cinza"
                    app:tint="#555555"/>
                <TextView
                    android:text="Configurações"
                    android:textSize="13sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginStart="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#F0F0F0" android:layout_marginStart="46dp"/>

            <!-- Sair -->
            <LinearLayout
                android:id="@+id/itemSair"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/logout_red"
                    app:tint="#E53935"/>
                <TextView
                    android:text="Sair"
                    android:textSize="13sp"
                    android:textColor="#E53935"
                    android:layout_marginStart="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>