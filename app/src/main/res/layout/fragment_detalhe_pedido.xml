<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Alça visual -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#DEDEDE"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalhes do Pedido"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:id="@+id/txtPedidoId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="2dp"
                android:text="#abc123"/>

        </LinearLayout>

        <TextView
            android:id="@+id/txtStatusDetalhe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="PAGO"
            android:background="@drawable/bg_status_badge"/>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>

    <!-- ScrollView para conteúdo -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp">

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressDetalhe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="visible"/>

            <!-- Seção: Comprador -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMPRADOR"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="#9E9E9E"
                android:visibility="gone"
                android:id="@+id/labelComprador"/>

            <LinearLayout
                android:id="@+id/layoutInfoComprador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtNomeComprador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:text="Nome do cliente"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 "
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/txtTelefone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#424242"
                        android:text="Não informado"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✉️ "
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/txtEmailComprador"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#424242"
                        android:text="email@email.com"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:id="@+id/layoutEndereco">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 "
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/txtEndereco"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#424242"
                        android:text="Cidade, Estado"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginVertical="16dp"
                android:id="@+id/divider1" android:visibility="gone"/>

            <!-- Seção: Itens -->
            <TextView
                android:id="@+id/labelItens"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITENS DO PEDIDO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="#9E9E9E"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/containerItens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"/>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginVertical="16dp"
                android:id="@+id/divider2" android:visibility="gone"/>

            <!-- Seção: Pagamento + Total -->
            <LinearLayout
                android:id="@+id/layoutPagamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="💳  Forma de pagamento"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"/>

                <TextView
                    android:id="@+id/txtFormaPagamento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:text="Pix"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:id="@+id/txtTotalDetalhe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:text="R$ 0,00"/>

            </LinearLayout>

            <!-- Botão: Aceitar pedido -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAceitarDetalhe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="✓  Aceitar Pedido"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

            <!-- Botão: Ver no Maps -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerMapa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="🗺  Ver localização no Maps"
                android:textColor="#1565C0"
                android:textSize="15sp"
                app:backgroundTint="#E3F2FD"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>