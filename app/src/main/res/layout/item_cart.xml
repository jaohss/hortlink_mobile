<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Foto do produto -->
        <ImageView
            android:id="@+id/iv_produto"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:background="#F1F8E9"
            android:padding="4dp" />

        <!-- Informações do produto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_nome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nome do produto"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_preco_unitario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00 / kg"
                android:textColor="#757575"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <!-- Controle de quantidade -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:background="#F1F8E9"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/btn_diminuir"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/remove_white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#2E7D32"
                    android:contentDescription="Diminuir quantidade" />

                <TextView
                    android:id="@+id/tv_quantidade"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#212121"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <ImageButton
                    android:id="@+id/btn_aumentar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/add_green700"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#2E7D32"
                    android:contentDescription="Aumentar quantidade" />

            </LinearLayout>

        </LinearLayout>

        <!-- Subtotal e remover (coluna direita) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tv_subtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="#2E7D32"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_remover"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/delete_green700"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#E53935"
                android:layout_marginTop="12dp"
                android:contentDescription="Remover item" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>